# EEWA — copy to .env and fill values

NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/eewa?schema=public"

# JWT (use long random secrets in production)
JWT_SECRET=your-super-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AES-256 key: 32 bytes = 64 hex characters. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Session inactivity (minutes) — align with JWT_EXPIRES_IN for UX
SESSION_INACTIVITY_MINUTES=15

LOG_LEVEL=info

# Frontend origin for CORS (default: Vite dev server)
CORS_ORIGIN=http://localhost:5173
